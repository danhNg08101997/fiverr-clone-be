datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
  // output = "../node_modules/@prisma/client-mysql"
}

model NguoiDung {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password      String
  phone         String?
  birthday      String?
  gender        Boolean?
  role          String   @default("USER")
  skill         Json? //lưu theo kiểu String[] nhưng MySQL ko support như Postgres => Json là kiểu thay thế
  certification Json?
  refresh_token String?

  thueCongViec ThueCongViec[]
  binhLuans    BinhLuan[]
}

model ThueCongViec {
  id            Int       @id @default(autoincrement())
  ma_cong_viec  Int
  ma_nguoi_thue Int
  ngay_thue     DateTime
  hoan_thanh    Boolean
  NguoiDung     NguoiDung @relation(fields: [ma_nguoi_thue], references: [id])
  CongViec      CongViec  @relation(fields: [ma_cong_viec], references: [id])
}

model CongViec { //Gig
  id                  Int                 @id @default(autoincrement())
  ten_cong_viec       String
  danh_gia            Int
  gia_tien            Int
  nguoi_tao           String
  hinh_anh            String
  mo_ta               String
  mo_ta_ngan          String
  sao_cong_viec       Int
  ma_chi_tiet_loai    Int
  ThueCongViecs       ThueCongViec[]
  BinhLuans           BinhLuan[] // Quan hệ ngược với BinhLuan
}

model NhomChiTietLoaiCongViec {
  id                Int          @id @default(autoincrement())
  ten_nhom          String
  hinh_anh          String
  ma_loai_cong_viec Int
  LoaiCongViec      LoaiCongViec @relation(fields: [ma_loai_cong_viec], references: [id])
  ChiTietLoaiCongViec ChiTietLoaiCongViec[]
}

model ChiTietLoaiCongViec {
  id                Int @id @default(autoincrement())
  ten_chi_tiet      String
  ma_nhom_chi_tiet_loai_cong_viec Int
  NhomChiTietLoaiCongViec NhomChiTietLoaiCongViec @relation(fields: [ma_nhom_chi_tiet_loai_cong_viec], references: [id])
}

model LoaiCongViec {
  id                  Int                   @id @default(autoincrement())
  ten_loai_cong_viec  String
  NhomChiTietLoaiCongViec NhomChiTietLoaiCongViec[]
}

model BinhLuan {
  id                 Int       @id @default(autoincrement())
  ma_cong_viec       Int
  ma_nguoi_binh_luan Int
  ngay_binh_luan     DateTime
  noi_dung           String
  sao_binh_luan      Int
  CongViec           CongViec  @relation(fields: [ma_cong_viec], references: [id])
  NguoiDung          NguoiDung @relation(fields: [ma_nguoi_binh_luan], references: [id])
}
