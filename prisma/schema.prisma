datasource db {
  provider = "mysql" // Chọn PostgreSQL, MySQL, hoặc SQLite
}

generator client {
  provider = "prisma-client-js"
  // output = "../node_modules/@prisma/client-mysql"
}

model NguoiDung {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  pass_word     String
  phone         String?
  birth_day     DateTime?
  gender        Boolean?
  role          String   @default("USER")
  skill         String?
  certification String?
  thueCongViec  ThueCongViec[]
  binhLuans     BinhLuan[]
  refresh_token String?
}

model ThueCongViec {
  id           Int      @id @default(autoincrement())
  ma_cong_viec Int
  ma_nguoi_thue Int
  ngay_thue    DateTime
  hoan_thanh   Boolean
  NguoiDung    NguoiDung @relation(fields: [ma_nguoi_thue], references: [id])
  CongViec     CongViec  @relation(fields: [ma_cong_viec], references: [id])
}

model CongViec {
  id                  Int                    @id @default(autoincrement())
  ten_cong_viec       String
  danh_gia            Int
  gia_tien            Int
  hinh_anh            String
  mo_ta               String
  mo_ta_ngan          String
  sao_cong_viec       Int
  ma_chi_tiet_loai    Int
  ChiTietLoaiCongViec ChiTietLoaiCongViec   @relation(fields: [ma_chi_tiet_loai], references: [id])
  ThueCongViecs       ThueCongViec[]
  BinhLuans           BinhLuan[]             // Quan hệ ngược với BinhLuan
}

model ChiTietLoaiCongViec {
  id                  Int              @id @default(autoincrement())
  ten_chi_tiet        String
  hinh_anh            String
  ma_loai_cong_viec   Int
  LoaiCongViec        LoaiCongViec     @relation(fields: [ma_loai_cong_viec], references: [id])
  CongViecs           CongViec[]       // Quan hệ ngược với CongViec
}

model LoaiCongViec {
  id            Int      @id @default(autoincrement())
  ten_loai_cong_viec String
  ChiTietLoaiCongViec ChiTietLoaiCongViec[]
}

model BinhLuan {
  id            Int      @id @default(autoincrement())
  ma_cong_viec  Int
  ma_nguoi_binh_luan Int
  ngay_binh_luan DateTime
  noi_dung      String
  sao_binh_luan Int
  CongViec      CongViec @relation(fields: [ma_cong_viec], references: [id])
  NguoiDung     NguoiDung @relation(fields: [ma_nguoi_binh_luan], references: [id])
}