datasource db {
  provider = "postgresql"
  schemas  = ["fiverr_clone"]
}

generator client {
  provider = "prisma-client-js"
}

model NguoiDung {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  password      String
  phone         String?
  birthday      String?
  gender        Boolean?
  role          String        @default("USER")
  skill         Json?
  certification Json?
  refresh_token String?
  avatar        String?       @db.Text
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  thueCongViec  ThueCongViec[]
  binhLuans     BinhLuan[]
  CongViec      CongViec[]

  @@map("NguoiDung")
  @@schema("fiverr_clone")
}

model ThueCongViec {
  id            Int       @id @default(autoincrement())
  ma_cong_viec  Int
  ma_nguoi_thue Int
  ngay_thue     DateTime
  hoan_thanh    Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  NguoiDung     NguoiDung @relation(fields: [ma_nguoi_thue], references: [id])
  CongViec      CongViec  @relation(fields: [ma_cong_viec], references: [id])

  @@index([ma_cong_viec])
  @@index([ma_nguoi_thue])
  @@map("ThueCongViec")
  @@schema("fiverr_clone")

}

model CongViec {
  id                  Int                 @id @default(autoincrement())
  ten_cong_viec       String
  danh_gia            Int                 @default(0)
  gia_tien            Int
  nguoi_tao           Int
  hinh_anh            String?             @db.Text
  mo_ta               String              @db.Text
  mo_ta_ngan          String              @db.Text
  sao_cong_viec       Int                 @default(0)
  ma_chi_tiet_loai    Int
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  ThueCongViecs       ThueCongViec[]
  BinhLuans           BinhLuan[]
  ChiTietLoaiCongViec ChiTietLoaiCongViec @relation(fields: [ma_chi_tiet_loai], references: [id])
  NguoiDung           NguoiDung           @relation(fields: [nguoi_tao], references: [id])

  @@index([ma_chi_tiet_loai])
  @@index([nguoi_tao])
  @@map("CongViec")
  @@schema("fiverr_clone")

}

model NhomChiTietLoaiCongViec {
  id                   Int                   @id @default(autoincrement())
  ten_nhom             String
  hinh_anh             String?
  ma_loai_cong_viec    Int
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt

  LoaiCongViec         LoaiCongViec          @relation(fields: [ma_loai_cong_viec], references: [id])
  ChiTietLoaiCongViecs ChiTietLoaiCongViec[]

  @@index([ma_loai_cong_viec])
  @@map("NhomChiTietLoaiCongViec")
  @@schema("fiverr_clone")

}

model ChiTietLoaiCongViec {
  id                              Int                     @id @default(autoincrement())
  ten_chi_tiet                    String
  ma_nhom_chi_tiet_loai_cong_viec Int
  created_at                      DateTime                @default(now())
  updated_at                      DateTime                @updatedAt

  NhomChiTietLoaiCongViec         NhomChiTietLoaiCongViec @relation(fields: [ma_nhom_chi_tiet_loai_cong_viec], references: [id])
  CongViecs                       CongViec[]

  @@index([ma_nhom_chi_tiet_loai_cong_viec])
  @@map("ChiTietLoaiCongViec")
  @@schema("fiverr_clone")

}

model LoaiCongViec {
  id                       Int                      @id @default(autoincrement())
  ten_loai_cong_viec       String
  created_at               DateTime                 @default(now())
  updated_at               DateTime                 @updatedAt

  NhomChiTietLoaiCongViecs NhomChiTietLoaiCongViec[]

  @@map("LoaiCongViec")
  @@schema("fiverr_clone")

}

model BinhLuan {
  id                 Int       @id @default(autoincrement())
  ma_cong_viec       Int
  ma_nguoi_binh_luan Int
  ngay_binh_luan     DateTime
  noi_dung           String    @db.Text
  sao_binh_luan      Int
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  CongViec           CongViec  @relation(fields: [ma_cong_viec], references: [id])
  NguoiDung          NguoiDung @relation(fields: [ma_nguoi_binh_luan], references: [id])

  @@index([ma_cong_viec])
  @@index([ma_nguoi_binh_luan])
  @@map("BinhLuan")
  @@schema("fiverr_clone")

}